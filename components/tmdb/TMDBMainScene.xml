<?xml version="1.0" encoding="utf-8" ?> 

<component name="TMDBMainScene" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/tmdb/TMDBMainScene.brs" />

     <children>
        <MarkupList
          id="ListMarkupList"
          itemComponentName="ListListItem"
          itemSize="[250, 30]"
          itemSpacing="[0, 8]"
          translation="[100,50]"
          focusBitmapBlendColor = "0x99999999" 
          numRows = "4"
      >
          <ContentNode role="content">
            <ListListItemData name="Watchlist Movies" list_type="watchlist" media_type="movies"/>     
            <ListListItemData name="Watchlist TV" list_type="watchlist" media_type="tv"/>  
            <ListListItemData name="Favorite Movies" list_type="favorite" media_type="movies"/>     
            <ListListItemData name="Favorite TV" list_type="favorite" media_type="tv"/>    
            <ListListItemData name="Rated Movies" list_type="rated" media_type="movies"/>     
            <ListListItemData name="Rated TV" list_type="rated" media_type="tv"/>          
          </ContentNode>
        </MarkupList>

   
    <LayoutGroup layoutDirection="horiz" vertAlignment="bottom" itemSpacings="[0, 0]" translation="[100,255]" >
        <Label text="Title" font="font:SmallBoldSystemFont" width="500" color="0xffffffff" />
        <Label text="Popularity" font="font:SmallBoldSystemFont" width="200" color="0xffffffff" />
        <Label text="Vote Average" font="font:SmallBoldSystemFont" width="200" color="0xffffffff" />
        <Label text="Release Date" font="font:SmallBoldSystemFont" width="200" color="0xffffffff" />
    </LayoutGroup>
        <MarkupList
          id="MediaMarkupList"
          itemComponentName="MediaListItem"
          itemSize="[1080, 25]"
          itemSpacing="[0, 8]"
          translation="[100,260]"
          focusBitmapBlendColor = "0x99999999" 
        />
    </children> 

</component>
