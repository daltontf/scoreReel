<?xml version="1.0" encoding="utf-8" ?>
<component name="WeatherListItem" extends="Group">
 
  <interface> 
    <field id="itemContent" type="node" onChange="itemContentChanged"/>
  </interface>
 
  <script type="text/brightscript" uri="pkg:/components/weather/WeatherListItem.brs" />

  <children> 
    <LayoutGroup layoutDirection="horiz" vertAlignment="bottom" itemSpacings="[0, 0]" translation="[0,25]" >
      <Label id="startTime" font="font:SmallestSystemFont" width="300" color="0xffff00ff" />
      <Label id="temperature" font="font:SmallestSystemFont" width="100" color="0xffffffff" />
      <Label id="probabilityOfPrecipitation" font="font:SmallestSystemFont" width="100" color="0xffffffff" />
      <Label id="windSpeed" font="font:SmallestSystemFont" width="150" color="0xffffffff" />
      <Label id="windDirection" font="font:SmallestSystemFont" width="50" color="0xffffffff" />
      <Label id="shortForecast" font="font:SmallestSystemFont" width="550" color="0xffffffff" />
    </LayoutGroup>
  </children>

</component>
