<?xml version="1.0" encoding="utf-8" ?>
<component name="WeatherListItem" extends="Group">
 
  <interface> 
    <field id="itemContent" type="node" onChange="itemContentChanged"/>
  </interface>
 
  <script type="text/brightscript" uri="pkg:/components/weather/WeatherListItem.brs" />

  <children> 
    <Group >
      <Label id="startTime" font="font:SmallestSystemFont" width="200" color="0xffff00ff" />
      <Label id="temperature" font="font:SmallestSystemFont" width="100" color="0xffffffff" translation="[200, 0]"/>
      <Label id="probabilityOfPrecipitation" font="font:SmallestSystemFont" width="100" color="0xffffffff" translation="[300, 0]" />
      <Label id="windSpeed" font="font:SmallestSystemFont" width="150" color="0xffffffff" translation="[405, 0]" />
      <Label id="windDirection" font="font:SmallestSystemFont" width="50" color="0xffffffff" translation="[555, 0]" />
      <Poster id="icon" width="30" height="30" translation="[605, 0]" />
      <Label id="shortForecast" font="font:SmallestSystemFont" width="550" color="0xffffffff" translation="[650, 0]" />
    </Group>
  </children>

</component>
